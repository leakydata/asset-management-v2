# Caterpillar Asset Management V2 — MCP Server credentials
# Copy to .env and fill in. Never commit .env.

# --- OAuth2 client credentials (Microsoft Entra ID) ---
CAT_CLIENT_ID=
CAT_CLIENT_SECRET=
# Scope is the target API's client ID followed by /.default, e.g. 11111111-2222-...-default
CAT_SCOPE=

# --- Optional: usually leave as default ---
# Entra tenant (defaulted from the OpenAPI spec)
CAT_TENANT_ID=ceb177bf-013b-49ab-8a9c-4abce32afc1e
# Full token URL (overrides CAT_TENANT_ID if set)
# CAT_TOKEN_URL=
# API base URL
CAT_BASE_URL=https://services.cat.com/catDigital/assetManagement/v2

# Default dealer code (partyNumber) used when a tool call omits it.
# During onboarding set this to your entitled TEST dealer code; switch to your
# real dealer code once Caterpillar upgrades your credentials.
# CAT_DEFAULT_PARTY_NUMBER=

# --- Optional: API gateway subscription key, if your onboarding requires one ---
# CAT_SUBSCRIPTION_KEY=
# CAT_SUBSCRIPTION_HEADER=x-api-key

# --- Optional: transport / runtime ---
# CAT_MCP_PORT=8765
# CAT_HTTP_TIMEOUT=30
